# ==========================================
# monicamontufar.com - Configuración de Entorno
# ==========================================

# 1. Netlify Serverless / Runtime
# ── Cloudflare Turnstile (anti-bot CAPTCHA)
# Obtén tu clave secreta en: https://dash.cloudflare.com → Turnstile
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Resend (email transaccional)
# Crea tu API Key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Email donde recibes las notificaciones de nuevas suscripciones
CONTACT_EMAIL=hola@monicamontufar.com
# Email remitente (debe ser un dominio verificado en Resend)
# Para verificar: https://resend.com/domains → Add Domain → monicamontufar.com
FROM_EMAIL=noreply@monicamontufar.com

# 2. Sentry Observability (Frontend/Astro)
# PUBLIC_ prefix → expuesto al navegador (el DSN de Sentry es seguro como público).
# Leído en sentry.client.config.ts como import.meta.env.PUBLIC_SENTRY_DSN
# En Netlify: Site configuration > Environment variables > PUBLIC_SENTRY_DSN
PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# 3. GitHub Actions CI (Secrets del Repositorio)
# Para cargar Source-Maps ofuscados a Sentry y tener monitoreo 10/10 Quirúrgico
# Agrega este token en Github: Settings > Secrets and variables > Actions
# El pipeline leerá este secreto automáticamente.
SENTRY_AUTH_TOKEN=sntrys_...
