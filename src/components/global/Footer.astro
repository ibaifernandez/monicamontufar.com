---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const portfolioUrl = 'https://portafolio.monicamontufar.com/';

const footerLinks = lang === 'en'
  ? [
      { href: '/en/',           label: 'Home'             },
      { href: '/en/about-me/',  label: 'About Me'         },
      { href: portfolioUrl,     label: 'Portfolio',        external: true },
      { href: '/en/blog/',      label: 'Blog'             },
      { href: '/contacto/',     label: 'Contact'          },
      { href: '/en/politica-de-privacidad-y-cookies/', label: 'Privacy & Cookies' },
      { href: '/en/legal-information/', label: 'Legal Information' },
    ]
  : [
      { href: '/',              label: 'Inicio'                },
      { href: '/sobre-mi/',     label: 'Sobre Mí'              },
      { href: portfolioUrl,     label: 'Portafolio',           external: true },
      { href: '/blog/',         label: 'Blog'                   },
      { href: '/contacto/',     label: 'Contacto'              },
      { href: '/politica-de-privacidad-y-cookies/', label: 'Privacidad y Cookies' },
      { href: '/informacion-legal/', label: 'Información Legal' },
    ];

const homeHref = lang === 'en' ? '/en/' : '/';
const year = new Date().getFullYear();
---

<footer class="bg-[#0f0e0b] border-t border-white/5 mt-auto">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16">

    <!-- Top: Logo + tagline + nav -->
    <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-10 pb-12 border-b border-white/5">

      <!-- Brand -->
      <div class="flex flex-col gap-4 max-w-xs">
        <a href={homeHref} aria-label="Mónica Montúfar" class="hover:opacity-80 transition-opacity">
          <img src="/images/logo-full.png" alt="Mónica Montúfar" class="h-10 w-auto object-contain" width="200" height="40" />
        </a>
        <p class="text-sm text-slate-400 font-light leading-relaxed">
          {lang === 'en'
            ? 'Digital nomad · Graphic designer · Virtual assistant. Creating from wherever the world takes me.'
            : 'Nómada digital · Diseñadora gráfica · Asistente virtual. Creando desde donde el mundo me lleve.'}
        </p>
      </div>

      <!-- Nav links -->
      <nav aria-label={lang === 'en' ? 'Footer navigation' : 'Navegación del pie'}>
        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-x-12 gap-y-3 list-none m-0 p-0" role="list">
          {footerLinks.map(link => (
            <li>
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                class="text-sm text-slate-400 hover:text-white transition-colors duration-200 font-medium"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Social icons -->
      <div class="flex items-center gap-4">
        <a href="https://www.facebook.com/lospensamientosdeMon" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
           class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary/40 transition-all duration-200">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href="https://www.instagram.com/los_pensamientos_de_mon" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
           class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary/40 transition-all duration-200">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href="https://www.tiktok.com/@los_pensamientos_de_mon" target="_blank" rel="noopener noreferrer" aria-label="TikTok"
           class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary/40 transition-all duration-200">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
          </svg>
        </a>
        <a href="mailto:hola@monicamontufar.com" aria-label="Email"
           class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary/40 transition-all duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom: copyright + credits -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
      <p class="text-xs text-slate-400">
        © {year} Mónica Montúfar.
        {lang === 'en' ? 'All rights reserved.' : 'Todos los derechos reservados.'}
      </p>
      <p class="text-xs text-slate-400">
        {lang === 'en' ? 'Crafted with' : 'Desarrollado con'} ❤️ {lang === 'en' ? 'by' : 'por'}
        <a href="https://portfolio.ibaifernandez.com/" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-primary transition-colors underline underline-offset-2">Ibai Fernández</a>
        {lang === 'en' ? 'and' : 'y'}
        <a href="https://monicamontufar.com/" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-primary transition-colors underline underline-offset-2">Mónica Montúfar</a>
        @
        <a href="https://aglaya.biz/" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-white transition-colors underline underline-offset-2 font-semibold">AGLAYA</a>
      </p>
    </div>
  </div>
</footer>
