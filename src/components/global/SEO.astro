---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
  lang?: string;
  /** URL explícita de la versión alternativa (el otro idioma).
   *  Necesario cuando la ruta no es simétrica, ej. /sobre-mi ↔ /en/about-me */
  alternateHref?: string;
  /** Pasar true para omitir las etiquetas hreflang alternate (páginas sin versión EN). */
  omitAlternate?: boolean;
}

const {
  title,
  description,
  image = '/images/monica-portrait.jpg',
  canonicalUrl = Astro.url.href,
  lang = 'es',
  alternateHref,
  omitAlternate = false,
} = Astro.props;

const site = String(Astro.site || 'https://monicamontufar.com').replace(/\/$/, '');
const alternateLang = lang === 'es' ? 'en' : 'es';

// Si se pasa alternateHref explícito se usa directamente (rutas asimétricas).
// Si no, se infiere simétricamente — solo es correcto para home y rutas espejo.
const alternateUrl = alternateHref ?? (
  lang === 'es'
    ? `${site}/en${Astro.url.pathname}`
    : `${site}${Astro.url.pathname.replace(/^\/en/, '')}`
);
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- i18n Hreflang Tags (Crucial against SEO cannibalization) -->
{!omitAlternate && (
  <>
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={`${Astro.site || 'https://monicamontufar.com'}/`} />
  </>
)}

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalUrl} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />
