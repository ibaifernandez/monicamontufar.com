---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = lang === 'en'
  ? [
      { href: '/en/',          label: 'Home'       },
      { href: '/en/about-me/', label: 'About Me'   },
      { href: '/en/portfolio/', label: 'Portfolio'  },
      { href: '/blog/',        label: 'Blog'        },
      { href: '/contacto/',    label: 'Contact'     },
    ]
  : [
      { href: '/',             label: 'Inicio'     },
      { href: '/sobre-mi/',    label: 'Sobre Mí'   },
      { href: '/portafolio/',  label: 'Portafolio' },
      { href: '/blog/',        label: 'Blog'        },
      { href: '/contacto/',    label: 'Contacto'    },
    ];

const homeHref = lang === 'en' ? '/en/' : '/';
const altHref  = lang === 'en' ? '/'    : '/en/';
const altImg   = lang === 'en' ? '/images/spain.svg'   : '/images/english.svg';
const altTitle = lang === 'en' ? 'Cambiar a Español'   : 'Switch to English';

function isActive(href: string): boolean {
  if (href === '/' || href === '/en/') return pathname === href;
  return pathname.startsWith(href);
}
---

<header
  id="site-navbar"
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[#12110E]/80 backdrop-blur-md transition-shadow duration-300"
>
  <nav
    class="max-w-7xl mx-auto px-6 lg:px-12 h-16 flex items-center justify-between gap-6"
    aria-label={lang === 'en' ? 'Main navigation' : 'Navegación principal'}
  >
    <!-- ── Logo ─────────────────────────────────────────────────────────── -->
    <a
      href={homeHref}
      aria-label={lang === 'en' ? 'Mónica Montúfar — Home' : 'Mónica Montúfar — Inicio'}
      class="hover:opacity-80 transition-opacity shrink-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60 rounded"
    >
      <img
        src="/images/logo-full.png"
        alt="Mónica Montúfar"
        class="h-8 lg:h-9 w-auto object-contain"
        width="180"
        height="36"
      />
    </a>

    <!-- ── Desktop nav links ─────────────────────────────────────────────── -->
    <ul class="hidden lg:flex items-center gap-8 list-none m-0 p-0" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class={[
              'text-sm font-semibold tracking-wide transition-colors duration-200 relative group',
              isActive(link.href)
                ? 'text-primary'
                : 'text-slate-300 hover:text-white',
            ].join(' ')}
          >
            {link.label}
            <span class={[
              'absolute -bottom-1 left-0 h-px w-full origin-left scale-x-0 bg-primary transition-transform duration-300 group-hover:scale-x-100',
              isActive(link.href) ? 'scale-x-100' : '',
            ].join(' ')} />
          </a>
        </li>
      ))}
    </ul>

    <!-- ── Right cluster ─────────────────────────────────────────────────── -->
    <div class="flex items-center gap-3 sm:gap-4">

      <!-- Social icons (desktop only) -->
      <div class="hidden sm:flex items-center gap-3 border-r border-white/10 pr-4">
        <a
          href="https://www.facebook.com/lospensamientosdeMon"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="text-slate-400 hover:text-primary transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
          </svg>
        </a>
        <a
          href="https://www.instagram.com/los_pensamientos_de_mon"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="text-slate-400 hover:text-primary transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/m%C3%B3nica-mont%C3%BAfar-qui%C3%B1%C3%B3nez-751123146/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-slate-400 hover:text-primary transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <!-- Language switcher -->
      <a
        href={altHref}
        title={altTitle}
        aria-label={altTitle}
        class="rounded-full overflow-hidden border-2 border-transparent hover:border-primary/50 transition-all hover:scale-110 active:scale-95 w-7 h-7 flex items-center justify-center shrink-0"
      >
        <img src={altImg} alt={altTitle} class="w-5 h-5 object-cover rounded-full" width="20" height="20" />
      </a>

      <!-- Hamburger (mobile only) -->
      <button
        id="nav-hamburger"
        type="button"
        aria-label={lang === 'en' ? 'Open menu' : 'Abrir menú'}
        aria-expanded="false"
        aria-controls="nav-mobile-menu"
        class="lg:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60"
      >
        <span class="nav-bar block h-0.5 w-5 bg-slate-300 transition-all duration-300 origin-center"></span>
        <span class="nav-bar block h-0.5 w-5 bg-slate-300 transition-all duration-300"></span>
        <span class="nav-bar block h-0.5 w-5 bg-slate-300 transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </nav>

  <!-- ── Mobile menu ────────────────────────────────────────────────────── -->
  <div
    id="nav-mobile-menu"
    class="lg:hidden hidden border-t border-white/5 bg-[#0f0e0b]"
    aria-hidden="true"
  >
    <ul class="px-6 py-6 flex flex-col gap-5 list-none m-0 p-6" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class={[
              'block text-base font-semibold tracking-wide transition-colors duration-200',
              isActive(link.href) ? 'text-primary' : 'text-slate-200 hover:text-white',
            ].join(' ')}
          >
            {link.label}
          </a>
        </li>
      ))}
      <!-- Mobile socials -->
      <li class="pt-4 border-t border-white/10 flex items-center gap-5">
        <a href="https://www.facebook.com/lospensamientosdeMon" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-slate-400 hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
        </a>
        <a href="https://www.instagram.com/los_pensamientos_de_mon" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-slate-400 hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
        </a>
        <a href="https://www.tiktok.com/@los_pensamientos_de_mon" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="text-slate-400 hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/></svg>
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  function initNavbar() {
    const btn  = document.getElementById('nav-hamburger');
    const menu = document.getElementById('nav-mobile-menu');
    const bars = btn?.querySelectorAll('.nav-bar');

    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(isOpen));
      menu.setAttribute('aria-hidden', String(!isOpen));

      // Animate bars → X when open
      if (bars && bars.length === 3) {
        if (isOpen) {
          (bars[0] as HTMLElement).style.transform = 'translateY(8px) rotate(45deg)';
          (bars[1] as HTMLElement).style.opacity   = '0';
          (bars[2] as HTMLElement).style.transform = 'translateY(-8px) rotate(-45deg)';
        } else {
          (bars[0] as HTMLElement).style.transform = '';
          (bars[1] as HTMLElement).style.opacity   = '';
          (bars[2] as HTMLElement).style.transform = '';
        }
      }
    });

    // Close on route change (Astro View Transitions)
    document.addEventListener('astro:page-load', () => {
      menu.classList.add('hidden');
      menu.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
      if (bars) {
        bars.forEach((b) => {
          (b as HTMLElement).style.transform = '';
          (b as HTMLElement).style.opacity   = '';
        });
      }
    });
  }

  document.addEventListener('astro:page-load', initNavbar);
  initNavbar();
</script>
