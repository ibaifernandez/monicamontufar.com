---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada • Mónica Montúfar"
  description="La página que buscas no existe. Vuelve al inicio."
  lang="es"
>
  <div class="relative min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <!-- Glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-[#e6b319]/5 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative z-10 max-w-lg space-y-6">
      <p class="text-8xl font-serif font-black text-[#e6b319] text-glow leading-none">404</p>
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-white">
        Esta página no existe
      </h1>
      <p class="text-white/70 font-sans font-light text-lg leading-relaxed">
        Parece que el enlace que seguiste está roto o la página se ha movido.<br/>
        No te preocupes, el inicio está a un clic.
      </p>
      <div class="pt-4 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-block px-8 py-4 bg-[#e6b319] text-[#12110e] font-sans font-semibold rounded-full hover:bg-white transition-colors duration-300 shadow-[0_4px_14px_0_rgba(230,179,25,0.39)]"
        >
          Volver al Inicio
        </a>
        <a
          href="https://portafolio.monicamontufar.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-4 border border-white/20 text-white font-sans font-semibold rounded-full hover:border-[#e6b319]/60 hover:text-[#e6b319] transition-colors duration-300"
        >
          Ver Portafolio
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
