---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

// ── Hero portrait
import imgHero     from '~/assets/wp-content/uploads/2024/04/MonMont.jpeg';
// ── About preview
import imgProfile  from '~/assets/wp-content/uploads/2025/06/Monica-Montufar.jpeg';
// ── Testimonial
import imgIbai     from '~/assets/testimonials/ibai.png';

// ── Blog post images (statically imported for Astro optimization)
import imgBlogNomada   from '~/assets/wp-content/uploads/2024/04/Nomada-digital-alojamiento.jpeg';
import imgBlogTatacoa  from '~/assets/wp-content/uploads/2025/04/Desierto_de_la_Tatacoa_Colombia_10.jpg';
import imgBlogStreet   from '~/assets/wp-content/uploads/2024/05/La-perseverancia.jpeg';
import imgBlogAirbnb   from '~/assets/wp-content/uploads/2025/05/Casa-Tomasa-Bogota.jpeg';

// ── Curated blog feed (4 posts, with manually mapped images + categories)
const featuredPosts = [
  {
    slug:     '9-pasos-a-seguir-para-iniciarte-como-nomada-digital',
    title:    '9 Pasos para iniciarte como nómada digital',
    excerpt:  'Todo lo que nadie te cuenta antes de lanzarte a trabajar desde cualquier lugar del mundo.',
    category: 'Nomadear',
    date:     '2024-07-12',
    image:    imgBlogNomada,
    imageAlt: 'Nómada digital trabajando con laptop en un café',
  },
  {
    slug:     'donde-el-silencio-habla-cronica-de-un-viaje-al-desierto-de-la-tatacoa',
    title:    'Donde el silencio habla: crónica de la Tatacoa',
    excerpt:  'Un viaje al corazón seco del Huila, donde la tierra se viste de rojo y el silencio suena profundo.',
    category: 'Andariega',
    date:     '2025-04-20',
    image:    imgBlogTatacoa,
    imageAlt: 'Paisaje árido del Desierto de la Tatacoa, Colombia',
  },
  {
    slug:     'street-food-en-bogota-un-festin-en-los-mercados-tradicionales',
    title:    '«Street Food» en Bogotá: un festín en los mercados',
    excerpt:  'Arepas, empanadas, chicha y mucho sabor callejero. La guía honesta de quien lo ha vivido.',
    category: 'Gastronomía',
    date:     '2024-05-28',
    image:    imgBlogStreet,
    imageAlt: 'Mercado tradicional de comida callejera en Bogotá',
  },
  {
    slug:     'mi-peor-experiencia-en-airbnb-una-advertencia-para-nomadas-digitales-y-viajeros',
    title:    'Mi peor experiencia en Airbnb',
    excerpt:  'Una advertencia honesta para nómadas digitales y viajeros: lo que nadie publica en su reseña.',
    category: 'Nomadear',
    date:     '2025-05-11',
    image:    imgBlogAirbnb,
    imageAlt: 'Interior de alojamiento tipo Casa Tomasa en Bogotá',
  },
];

// ── Helpers
function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });
}

const categoryColor: Record<string, string> = {
  'Nomadear':   'bg-sky-500/15 text-sky-300 border-sky-500/20',
  'Andariega':  'bg-emerald-500/15 text-emerald-300 border-emerald-500/20',
  'Gastronomía':'bg-orange-500/15 text-orange-300 border-orange-500/20',
};
---

<BaseLayout
  title="Mónica Montúfar — Nómada Digital, Diseñadora y Creativa"
  description="Soy Món Mont, nómada digital, diseñadora gráfica y asistente virtual desde LatAm para el mundo. Historias de viaje, creatividad y vida en libertad."
  ogImage="/images/og-home.jpg"
  lang="es"
  alternateHref="https://monicamontufar.com/en/"
>
  <!-- JSON-LD: Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Mónica Montúfar",
    "alternateName": "Món Mont",
    "url": "https://monicamontufar.com",
    "jobTitle": "Diseñadora Gráfica y Nómada Digital",
    "sameAs": [
      "https://www.instagram.com/los_pensamientos_de_mon",
      "https://www.linkedin.com/in/mónica-montúfar-quiñónez-751123146/",
      "https://www.facebook.com/lospensamientosdeMon",
      "https://www.tiktok.com/@los_pensamientos_de_mon"
    ]
  })} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO — Full-screen editorial split
  ═══════════════════════════════════════════════════════════════════════ -->
  <section class="relative flex flex-col lg:flex-row min-h-[calc(100vh-4rem)] w-full bg-[#12110E]" aria-label="Presentación">

    <!-- Left: text content -->
    <div class="flex-1 flex flex-col justify-center px-6 lg:px-16 xl:px-24 py-16 lg:py-0 z-10 order-2 lg:order-1">
      <div class="max-w-xl">

        <!-- Badge -->
        <span class="inline-flex items-center gap-2 py-1 px-4 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold tracking-widest uppercase mb-8">
          Nómada Digital · Diseñadora · Creativa
        </span>

        <!-- Heading -->
        <h1 class="font-serif leading-[0.92] mb-6 text-white">
          <span class="block text-3xl lg:text-4xl font-normal text-slate-300 mb-2">¡Hola! Soy</span>
          <span class="block text-6xl lg:text-[90px] xl:text-[110px] font-normal">Món</span>
          <span class="block text-6xl lg:text-[90px] xl:text-[110px] italic text-primary">Mont</span>
        </h1>

        <!-- Tagline -->
        <p class="text-lg lg:text-xl text-slate-300 font-light leading-relaxed mb-10 max-w-md">
          En 2023 empecé mi aventura como nómada digital. Acompáñame a descubrir el mundo del nomadismo, el diseño y la vida en libertad.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a
            href="/sobre-mi/"
            class="inline-flex items-center gap-2 bg-primary hover:bg-[#ffc926] text-[#12110E] px-7 py-3.5 rounded-full font-bold text-sm tracking-wide transition-all duration-200 shadow-[0_4px_20px_rgba(230,179,25,0.35)] hover:shadow-[0_6px_28px_rgba(230,179,25,0.5)]"
          >
            Sobre Mí
            <span class="material-symbols-outlined text-base">arrow_right_alt</span>
          </a>
          <a
            href="/blog/"
            class="inline-flex items-center gap-2 border border-white/20 hover:border-white/50 text-white px-7 py-3.5 rounded-full font-semibold text-sm tracking-wide transition-all duration-200 hover:bg-white/5"
          >
            Leer el blog
          </a>
        </div>
      </div>
    </div>

    <!-- Right: portrait photo -->
    <div class="flex-1 relative overflow-hidden h-[55vw] lg:h-auto lg:max-h-[calc(100vh-4rem)] order-1 lg:order-2 group">
      <!-- gradient overlay — fades into dark bg on the left on desktop -->
      <div class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-[#12110E] via-[#12110E]/50 to-transparent z-10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#12110E] to-transparent z-10 lg:hidden"></div>

      <Image
        src={imgHero}
        alt="Retrato editorial de Mónica Montúfar"
        widths={[480, 640, 960, 1280, 1920]}
        sizes="(max-width: 1024px) 100vw, 50vw"
        quality={80}
        class="absolute inset-0 w-full h-full object-center object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-105"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       STATS
  ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#1c1a14] border-y border-white/5" aria-label="Cifras">
    <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
      {[
        { value: '10',   suffix: '',  label: 'Historias publicadas' },
        { value: '100',  suffix: '+', label: 'Proyectos de diseño'  },
        { value: '3',    suffix: '+', label: 'Años como nómada'     },
        { value: '∞',    suffix: '',  label: 'Sueños por cumplir'   },
      ].map(stat => (
        <div class="flex flex-col items-center gap-1">
          <span class="font-serif text-5xl lg:text-6xl text-white text-glow">
            {stat.value}<span class="text-primary">{stat.suffix}</span>
          </span>
          <span class="text-xs font-semibold uppercase tracking-widest text-slate-400 mt-2">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ABOUT PREVIEW
  ═══════════════════════════════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-6 py-20 lg:py-28" aria-label="Sobre mí">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

      <!-- Photo -->
      <div class="w-full lg:w-5/12 shrink-0">
        <div class="relative group max-w-sm mx-auto lg:mx-0">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden border border-white/10 relative z-10 transition-transform duration-500 group-hover:-translate-y-2 group-hover:-translate-x-2">
            <Image
              src={imgProfile}
              alt="Mónica Montúfar, diseñadora y nómada digital"
              widths={[320, 480, 640]}
              sizes="(max-width: 768px) 90vw, (max-width: 1024px) 45vw, 380px"
              quality={85}
              class="w-full h-full object-cover object-top"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#12110e] via-transparent to-transparent opacity-50"></div>
          </div>
          <!-- decorative offset border -->
          <div class="absolute inset-0 border border-primary/30 rounded-2xl z-0 transition-transform duration-500 group-hover:translate-x-4 group-hover:translate-y-4 pointer-events-none"></div>
        </div>
      </div>

      <!-- Text -->
      <div class="w-full lg:w-7/12 space-y-7">
        <div>
          <p class="text-primary text-xs font-bold tracking-widest uppercase mb-3">Quién soy</p>
          <h2 class="font-serif text-4xl lg:text-5xl text-white leading-tight">
            El mundo creativo<br />de Món Mont
          </h2>
          <div class="w-12 h-0.5 bg-primary mt-5 rounded-full"></div>
        </div>

        <div class="space-y-5 text-slate-300 text-base lg:text-lg font-light leading-relaxed">
          <p>
            Soy <strong class="text-white font-medium">Mónica Montúfar</strong>, apasionada ecuatoriana con un trasfondo en hotelería y turismo que encontró su verdadera vocación en la creatividad visual. Desde el diseño gráfico hasta el diseño web, llevo años explorando nuevas fronteras y ayudando a marcas a alcanzar su máximo potencial en línea.
          </p>
          <p>
            Hoy combino mi trabajo como <strong class="text-primary font-medium">asistente virtual y diseñadora freelance</strong> con mi vida como nómada digital — convirtiendo cada destino en fuente de inspiración y cada proyecto en una historia que contar.
          </p>
        </div>

        <a
          href="/sobre-mi/"
          class="inline-flex items-center gap-2 text-primary hover:text-white font-semibold text-sm tracking-wide transition-colors duration-200 group"
        >
          Leer mi historia completa
          <span class="material-symbols-outlined text-base transition-transform duration-200 group-hover:translate-x-1">arrow_right_alt</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BLOG FEED — "Las últimas aventuras"
  ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#0f0e0b] border-t border-white/5 py-20 lg:py-28" aria-label="Últimas historias">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Header -->
      <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between gap-6 mb-14">
        <div>
          <p class="text-primary text-xs font-bold tracking-widest uppercase mb-3">Del blog</p>
          <h2 class="font-serif text-4xl lg:text-5xl text-white">Las últimas aventuras</h2>
        </div>
        <a
          href="/blog/"
          class="shrink-0 inline-flex items-center gap-2 border border-white/20 hover:border-primary/50 text-slate-300 hover:text-primary px-5 py-2.5 rounded-full text-sm font-semibold transition-all duration-200"
        >
          Ver todo
          <span class="material-symbols-outlined text-base">arrow_right_alt</span>
        </a>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredPosts.map((post, i) => (
          <article class="group flex flex-col rounded-2xl overflow-hidden bg-[#1c1a14] border border-white/5 hover:border-white/15 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(0,0,0,0.4)]">
            <!-- Image -->
            <a href={`/blog/${post.slug}/`} class="block overflow-hidden aspect-[4/3] shrink-0" aria-hidden="true" tabindex="-1">
              <Image
                src={post.image}
                alt={post.imageAlt}
                widths={[320, 480, 640]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
                quality={75}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </a>

            <!-- Content -->
            <div class="flex flex-col flex-1 p-5 gap-3">
              <div class="flex items-center justify-between gap-2">
                <span class={`text-[11px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full border ${categoryColor[post.category] ?? 'bg-white/5 text-slate-300 border-white/10'}`}>
                  {post.category}
                </span>
                <time datetime={post.date} class="text-xs text-slate-400 shrink-0">
                  {formatDate(post.date)}
                </time>
              </div>

              <h3 class="font-serif text-lg text-white leading-snug group-hover:text-primary transition-colors duration-200">
                <a href={`/blog/${post.slug}/`}>{post.title}</a>
              </h3>

              <p class="text-sm text-slate-400 font-light leading-relaxed flex-1">
                {post.excerpt}
              </p>

              <a
                href={`/blog/${post.slug}/`}
                class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:text-white transition-colors duration-200 mt-1 group/link"
              >
                Leer más
                <span class="material-symbols-outlined text-sm transition-transform duration-200 group-hover/link:translate-x-0.5">arrow_right_alt</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TESTIMONIAL
  ═══════════════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 lg:py-32 overflow-hidden" aria-label="Testimonial">
    <!-- ambient glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-primary/5 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">

      <!-- Quote mark -->
      <span class="font-serif text-8xl text-primary/20 leading-none block mb-0 select-none" aria-hidden="true">"</span>

      <blockquote class="font-serif text-xl lg:text-2xl xl:text-3xl text-white/90 leading-relaxed -mt-6 mb-10">
        Llegan severas turbulencias, el avión se parte por la mitad… yo estoy sentado en la mitad que se ha quedado sin motores… voy a echar mano… y no hay paracaídas… Justo en ese momento, hay solo una persona que me garantiza guardar la calma y una solución a medida:
        <strong class="text-primary not-italic"> Món Mont.</strong>
      </blockquote>

      <div class="flex flex-col items-center gap-3">
        <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-primary/40 ring-2 ring-primary/10">
          <Image
            src={imgIbai}
            alt="Ibai Fernández"
            width={56}
            height={56}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <p class="font-semibold text-white text-sm">Ibai Fernández</p>
          <p class="text-xs text-slate-400 font-light">Compañero de aventuras · <a href="https://aglaya.biz/" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-white transition-colors underline underline-offset-2">AGLAYA</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA — Sígueme en redes
  ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#1c1a14] border-t border-white/5 py-16" aria-label="Redes sociales">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="text-primary text-xs font-bold tracking-widest uppercase mb-4">Únete a la aventura</p>
      <h2 class="font-serif text-3xl lg:text-4xl text-white mb-4">Sígueme en redes</h2>
      <p class="text-slate-400 font-light mb-10 text-base">
        Comparto el día a día del nomadismo, trucos de diseño y las historias que no caben en el blog.
      </p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        {[
          { href: 'https://www.facebook.com/lospensamientosdeMon', label: 'Facebook', icon: 'M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z' },
          { href: 'https://www.instagram.com/los_pensamientos_de_mon', label: 'Instagram', icon: 'M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z' },
          { href: 'https://www.tiktok.com/@los_pensamientos_de_mon', label: 'TikTok', icon: 'M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z' },
        ].map(social => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
            class="flex items-center gap-3 bg-white/5 hover:bg-primary/10 border border-white/10 hover:border-primary/30 text-slate-300 hover:text-primary px-5 py-3 rounded-full font-semibold text-sm transition-all duration-200"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d={social.icon} clip-rule="evenodd" />
            </svg>
            {social.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
