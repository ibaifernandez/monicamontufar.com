---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';
import { thumbnails, thumbnailFallback } from '../../../data/blog-thumbnails';
import postsData from '../../../data/wp-archive/posts-en.json';

export async function getStaticPaths() {
  const posts = await import('../../../data/wp-archive/posts-en.json');
  return posts.default.map((post: any) => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props;
const thumb = thumbnails[post.slug] ?? thumbnailFallback;

// Clean any residual HTML wrappers / rewrite URLs
function cleanContent(html: string): string {
  return html
    .replace(/https?:\/\/localhost:\d+\//gi, '/')
    .replace(/<(div|section|article)[^>]*class="[^"]*elementor[^"]*"[^>]*>/gi, '')
    .replace(/<\/(div|section|article)>/gi, '')
    .replace(/\s*class="[^"]*elementor[^"]*"/gi, '')
    .replace(/\s*class=""\s*/gi, ' ')
    .replace(/<span\s*>([\s\n]*)<\/span>/gi, '$1')
    .replace(/\bcolor\s*:\s*[^;"}]+;?/gi, '')
    .replace(/data-elementor-lightbox-title="([^"]*)"/gi,
      'data-elementor-lightbox-title="$1" aria-label="$1"')
    .replace(/<a([^>]*)aria-label="Read more about [^"]*"([^>]*)>/gi, '<a$1$2>')
    .replace(/<a([^>]*)tabindex="-1"([^>]*)>/gi, '<a$1tabindex="-1"$2 aria-hidden="true">')
    .replace(/<h3(\s|>)/gi, '<h2$1')
    .replace(/<\/h3>/gi, '</h2>')
    .replace(/<h4(\s|>)/gi, '<h3$1')
    .replace(/<\/h4>/gi, '</h3>')
    .replace(/\n{3,}/g, '\n\n')
    .trim();
}

const title   = post.title?.rendered ?? '';
const rawExcerpt = post.excerpt?.rendered?.replace(/<[^>]+>/g, '').trim() ?? '';
// Fallback: if WP excerpt is too short/truncated, derive from content text
const excerpt = rawExcerpt.length >= 80
  ? rawExcerpt
  : (post.content?.rendered ?? '')
      .replace(/<[^>]+>/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()
      .slice(0, 160)
      .replace(/\s+\S*$/, '') + '…';
const content = cleanContent(post.content?.rendered ?? '');
const dateStr = new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const optimizedThumb = await getImage({ src: thumb, width: 1280 });
const thumbUrl = `https://monicamontufar.com${optimizedThumb.src}`;
const thumbWidth  = (optimizedThumb.attributes as any).width  ?? 1280;
const thumbHeight = (optimizedThumb.attributes as any).height ?? 720;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title.replace(/<[^>]+>/g, ''),
  "description": excerpt.slice(0, 160),
  "image": {
    "@type": "ImageObject",
    "url": thumbUrl,
    "width": thumbWidth,
    "height": thumbHeight
  },
  "url": `https://monicamontufar.com/en/blog/${post.slug}/`,
  "datePublished": post.date,
  "dateModified": post.modified ?? post.date,
  "author": {
    "@type": "Person",
    "name": "Mónica Montúfar",
    "url": "https://monicamontufar.com/en/about-me/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Mónica Montúfar",
    "url": "https://monicamontufar.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://monicamontufar.com/images/logo-full.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://monicamontufar.com/en/blog/${post.slug}/`
  }
};
---

<BaseLayout
  title={`${title.replace(/<[^>]+>/g,'')} • Mónica Montúfar Blog`}
  description={excerpt.slice(0, 160)}
  ogImage={thumbUrl}
  lang="en"
  omitAlternate={false}
  alternateHref={`/blog/${post.slug}/`}
>
  <!-- JSON-LD: BlogPosting -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Cover image -->
  <div class="relative w-full aspect-[16/6] md:aspect-[16/5] overflow-hidden">
    <Image
      src={thumb}
      alt={title.replace(/<[^>]+>/g,'')}
      widths={[768, 1280, 1600]}
      sizes="100vw"
      quality={80}
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#12110e]/30 to-[#12110e]"></div>
  </div>

  <!-- Post header -->
  <header class="max-w-3xl mx-auto px-6 pt-10 pb-6">
    <a href="/en/blog/" class="inline-flex items-center gap-2 text-sm font-sans text-slate-400 hover:text-[#e6b319] transition-colors duration-200 mb-8 group uppercase tracking-widest font-semibold">
      <span class="material-symbols-outlined text-lg group-hover:-translate-x-1 transition-transform">arrow_left_alt</span>
      Blog
    </a>
    <p class="text-xs font-sans text-slate-400 mb-4">{dateStr}</p>
    <h1 class="font-serif text-3xl md:text-5xl font-bold text-white leading-tight mb-6" set:html={title} />
    {excerpt && (
      <p class="font-sans text-white/70 text-lg font-light leading-relaxed border-l-2 border-[#e6b319]/40 pl-4">
        {excerpt.slice(0, 200)}{excerpt.length > 200 ? '…' : ''}
      </p>
    )}
  </header>

  <!-- Post content -->
  <article class="max-w-3xl mx-auto px-6 pb-20 prose-blog" set:html={content} />

  <!-- Back + CTA -->
  <div class="max-w-3xl mx-auto px-6 pb-16 pt-4 border-t border-white/5">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <a href="/en/blog/" class="inline-flex items-center gap-2 font-sans text-sm font-semibold uppercase tracking-widest text-slate-400 hover:text-white transition-colors duration-200 group">
        <span class="material-symbols-outlined text-lg group-hover:-translate-x-1 transition-transform">arrow_left_alt</span>
        Back to Blog
      </a>
      <a href="/contacto/" class="inline-block px-8 py-3 bg-[#e6b319] text-[#12110e] font-sans font-semibold rounded-full hover:bg-white transition-colors duration-300 text-sm shadow-[0_4px_14px_0_rgba(230,179,25,0.3)]">
        Let's Talk
      </a>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Prose styles — shared with ES blog */
  .prose-blog {
    color: rgba(248, 250, 252, 0.8);
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.85;
    font-weight: 300;
  }
  .prose-blog h1,
  .prose-blog h2,
  .prose-blog h3,
  .prose-blog h4 {
    font-family: var(--font-serif);
    font-weight: 700;
    color: #fff;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .prose-blog h2 { font-size: 1.375rem; }
  .prose-blog h3 { font-size: 1.125rem; }
  .prose-blog h4 { font-size: 1rem; }
  .prose-blog p  { margin-bottom: 1.25rem; }
  .prose-blog strong { color: #fff; font-weight: 600; }
  .prose-blog em { color: rgba(248,250,252,0.9); }
  .prose-blog a  { color: #e6b319; text-decoration: underline; text-underline-offset: 3px; transition: opacity 0.2s; }
  .prose-blog a:hover { opacity: 0.8; }
  .prose-blog ul,
  .prose-blog ol { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .prose-blog li { margin-bottom: 0.4rem; }
  .prose-blog ul { list-style-type: disc; }
  .prose-blog ol { list-style-type: decimal; }
  .prose-blog blockquote {
    border-left: 3px solid #e6b319;
    padding-left: 1.25rem;
    color: rgba(248,250,252,0.65);
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose-blog img {
    width: 100%;
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }
  .prose-blog hr {
    border-color: rgba(255,255,255,0.08);
    margin: 2rem 0;
  }
  .prose-blog .e-con-inner,
  .prose-blog .elementor-widget-container { display: contents; }
</style>
