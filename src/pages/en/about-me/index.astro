---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import InternalHero from '../../../components/sections/InternalHero.astro';
import { Image } from 'astro:assets';
import imgProfile from '~/assets/wp-content/uploads/2025/06/Monica-Montufar.jpeg';
---

<BaseLayout
  title="About Me • Mónica Montúfar"
  description="Creative by conviction, designer by vocation, digital nomad by decision."
  lang="en"
  alternateHref="https://monicamontufar.com/sobre-mi/"
>
  <InternalHero 
    title="About Me" 
    subtitle="Creative by conviction, designer by vocation, digital nomad by decision." 
    lang="en" 
  />

  <section class="max-w-5xl mx-auto px-6 py-12 md:py-24 space-y-16">
    <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-center">
      <div class="w-full md:w-5/12 relative group">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden border border-white/10 relative z-10 transition-transform duration-500 group-hover:-translate-y-2 group-hover:-translate-x-2">
          <Image
            src={imgProfile}
            alt="Mónica Montúfar"
            widths={[320, 480, 640, 960]}
            sizes="(max-width: 768px) 100vw, 42vw"
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#12110e] via-transparent to-transparent opacity-60"></div>
        </div>
        <div class="absolute inset-0 border border-[#e6b319]/40 rounded-2xl z-0 transition-transform duration-500 group-hover:translate-x-4 group-hover:translate-y-4"></div>
      </div>
      
      <div class="w-full md:w-7/12 space-y-8">
        <div>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-white">My Story</h2>
          <div class="w-12 h-1 bg-[#e6b319] mt-4 rounded-full"></div>
        </div>
        
        <div class="space-y-6 font-sans text-white/80 leading-relaxed text-lg font-light">
          <p>
            Proactive and experienced <strong class="text-white font-medium">Virtual Assistant</strong> with over 10 years in the digital ecosystem. My Master's in Digital Marketing and eCommerce has equipped me with a broad technical and strategic skillset.
          </p>
          <p>
            Advanced proficiency in <strong class="text-[#e6b319] font-medium">WordPress, Mailchimp, Brevo, Salesforce Email Studio, Illustrator, and After Effects</strong>. Specialist in <strong class="text-white font-medium">web design, email marketing, project management, and visual communication</strong>.
          </p>
          <p>
            I have created over 100 websites and successfully managed email marketing campaigns. My strengths include problem-solving, organization, adaptability, and effective communication. Accustomed to remote and autonomous work, I am ready to offer high-level virtual support, optimizing your operations and contributing to your business growth.
          </p>
        </div>
        
        <div class="pt-4">
          <a href="/en/portfolio" class="inline-block px-8 py-4 bg-[#e6b319] text-[#12110e] font-sans font-semibold rounded-full hover:bg-white transition-colors duration-300 shadow-[0_4px_14px_0_rgba(230,179,25,0.39)] hover:shadow-[0_6px_20px_rgba(255,255,255,0.23)]">
            View My Work
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
