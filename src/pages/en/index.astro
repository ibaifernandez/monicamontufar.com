---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import imgIcono from '~/assets/wp-content/uploads/2023/08/Icono-Mon.png';
import imgHero from '~/assets/wp-content/uploads/2024/04/MonMont.jpeg';
---

<BaseLayout 
  title="Mónica Montúfar - Coming Soon" 
  description="Crafting experiences that resonate and define the new standard of digital luxury."
  lang="en"
>
  <div class="relative min-h-screen flex flex-col w-full bg-[#12110E]">
    <!-- Top Navigation -->
    <header class="fixed top-0 w-full z-50 px-6 py-6 lg:px-12 flex items-center justify-between border-b border-white/5 bg-[#12110E]/80 backdrop-blur-md">
      <div class="flex items-center gap-3 hover:opacity-80 transition-opacity cursor-pointer">
        <Image src={imgIcono} alt="Icono Mónica Montúfar" width={32} height={32} class="size-8 object-contain" />
        <span class="text-xl font-bold tracking-tighter text-slate-100">Mónica Montúfar</span>
      </div>
      <div class="flex items-center gap-6">
        <!-- Social Icons -->
        <div class="flex items-center gap-4 border-r border-white/10 pr-6 mr-2 hidden sm:flex">
          <a aria-label="Facebook" href="https://www.facebook.com/lospensamientosdeMon" target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
          </a>
          <a aria-label="Instagram" href="https://www.instagram.com/los_pensamientos_de_mon" target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
          </a>
          <a aria-label="LinkedIn" href="https://www.linkedin.com/in/m%C3%B3nica-mont%C3%BAfar-qui%C3%B1%C3%B3nez-751123146/" target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" /></svg>
          </a>
        </div>
        
        <!-- Language Switcher Toggle (EN shows ES flag) -->
        <nav class="flex items-center relative ml-2">
          <a href="/" title="Cambiar a Español" class="transition-all hover:scale-110 active:scale-95 group rounded-full overflow-hidden shadow-lg border-2 border-transparent hover:border-primary/50 w-8 h-8 flex items-center justify-center bg-[#1c1a14]/50 backdrop-blur-md shrink-0">
            <img src="/images/spain.svg" alt="Cambiar a Español" class="w-5 h-5 object-cover rounded-full" />
          </a>
        </nav>
      </div>
    </header>

    <div class="flex-1 flex flex-col lg:flex-row pt-24 lg:pt-0">
      <!-- Left Content: Editorial Text -->
      <div class="flex-1 flex flex-col justify-center px-6 lg:px-24 py-12 lg:py-0 z-10">
        <div class="max-w-2xl mt-12 md:mt-0">
          <span class="inline-block py-1 px-3 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold tracking-widest uppercase mb-6">Coming Soon</span>
          
          <h1 class="font-serif text-6xl lg:text-[140px] mb-4 leading-[0.9] text-white">
            Mónica <br/>
            <span class="italic text-primary">Montúfar</span>
          </h1>
          
          <p class="text-lg lg:text-2xl text-slate-300 font-light leading-relaxed mb-6 max-w-lg mt-6">
            Hi there! I'm lovingly preparing this space to share my universe with you. Very soon you'll discover everything I've been creating for you.
          </p>

          <!-- CTA Form -->
          <div class="mb-12 mt-6" id="waitlist-section">
            <p class="text-sm font-medium text-primary mb-3 pl-2">Leave me your email and I'll let you know as soon as I open the doors (I promise not to spam!)</p>
            <div class="glass-effect p-2 rounded-2xl max-w-sm sm:max-w-md shadow-2xl bg-[#1c1a14]/60">
              <form id="waitlist-form" class="flex flex-col sm:flex-row gap-2" novalidate>
                <input type="text" name="bot_field" class="hidden" tabindex="-1" autocomplete="off" />
                <div class="relative flex-1 shrink-0">
                  <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-300">mail</span>
                  <input
                    id="waitlist-email"
                    name="email"
                    class="w-full pl-12 pr-4 py-3 sm:py-4 bg-transparent border-none focus:outline-none focus:ring-1 focus:ring-primary/50 text-slate-100 placeholder:text-slate-400 rounded-xl font-display"
                    placeholder="Your email address"
                    required
                    type="email"
                    autocomplete="email"
                  />
                </div>
                <button
                  id="waitlist-submit"
                  class="bg-primary hover:bg-[#ffc926] text-[#12110E] px-6 sm:px-8 py-3 sm:py-4 rounded-xl font-bold transition-all shadow-xl shadow-primary/10 whitespace-nowrap shrink-0 disabled:opacity-60 disabled:cursor-not-allowed"
                  type="submit"
                >
                  Let me know!
                </button>
              </form>
            </div>

            <div id="waitlist-success" class="hidden mt-4 pl-2 text-sm font-medium text-[#e6b319]">
              ✓ You're on the list! I'll reach out as soon as the doors open.
            </div>
            <div id="waitlist-error" class="hidden mt-4 pl-2 text-sm font-medium text-red-400"></div>

            <!-- Legal Checkbox -->
            <div class="mt-4 pl-2 flex items-start gap-3 max-w-md">
              <input type="checkbox" id="privacy-en" required class="mt-1 w-4 h-4 rounded border-white/20 bg-white/5 text-primary focus:ring-primary/50 opacity-70" />
              <label for="privacy-en" class="text-xs text-slate-300 font-light leading-snug">
                I have read and accept the <a href="/en/politica-de-privacidad-y-cookies" class="text-primary hover:text-white transition-colors underline decoration-primary/30 underline-offset-2">privacy and cookies policy</a> for the collection of my data.
              </label>
            </div>
          </div>

          <!-- Dynamic Countdown -->
          <div class="flex gap-6 mt-8 items-center">
            <div class="flex flex-col items-center">
              <span id="days" class="text-4xl font-serif text-white text-glow">00</span>
              <span class="text-[10px] uppercase tracking-widest text-[#e6b319] font-bold mt-1">Days</span>
            </div>
            <div class="h-8 w-px bg-white/10"></div>
            <div class="flex flex-col items-center">
              <span id="hours" class="text-4xl font-serif text-white text-glow">00</span>
              <span class="text-[10px] uppercase tracking-widest text-[#e6b319] font-bold mt-1">Hours</span>
            </div>
            <div class="h-8 w-px bg-white/10"></div>
            <div class="flex flex-col items-center">
              <span id="minutes" class="text-4xl font-serif text-white text-glow">00</span>
              <span class="text-[10px] uppercase tracking-widest text-[#e6b319] font-bold mt-1">Minutes</span>
            </div>
            <div class="h-8 w-px bg-white/10"></div>
            <div class="flex flex-col items-center">
              <span id="seconds" class="text-4xl font-serif text-white text-glow">00</span>
              <span class="text-[10px] uppercase tracking-widest text-[#e6b319] font-bold mt-1">Seconds</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Content: High-end Editorial Portrait -->
      <div class="flex-1 relative overflow-hidden h-[50vh] lg:h-screen group mt-12 lg:mt-0">
        <!-- Intense dark gradient that bleeds perfectly into the portrait -->
        <div class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-[#12110E] via-[#12110E]/60 to-transparent z-10"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#12110E] to-transparent z-10 lg:hidden"></div>
        
        <Image
          src={imgHero}
          alt="Mónica Montúfar Portrait"
          widths={[640, 960, 1280, 1920]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          class="absolute inset-0 w-full h-full object-center object-cover transition-transform duration-1000 group-hover:scale-105"
          loading="eager"
          fetchpriority="high"
        />
        
      </div>

    </div>

    <!-- Minimal Footer -->
    <footer class="bg-[#1c1a14] py-10 px-6 lg:px-24 border-t border-white/5 mt-12">
      <div class="flex flex-col items-center gap-4 text-center">
        <p class="text-xs text-slate-300 tracking-widest font-medium">© 2026 Mónica Montúfar. All rights reserved.</p>
        <p class="text-xs text-slate-300 font-light tracking-wide mt-2">
          Developed with ❤️, 🧠 and 🌈 by 
          <a href="https://portfolio.ibaifernandez.com/" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:text-white transition-colors">Ibai Fernández</a> and 
          <a href="https://portafolio.monicamontufar.com/" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:text-white transition-colors">Mónica Montúfar</a> @ 
          <a href="https://aglaya.biz/" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:text-white transition-colors font-semibold">AGLAYA</a> · 
          From LatAm to the 🌎
        </p>
      </div>
    </footer>
  </div>

  <script>
    function initCountdown() {
      // May 1st, 2026, 09:00 AM Colombia Time (UTC-5)
      const targetDate = new Date('2026-05-01T09:00:00-05:00').getTime();
      
      const elements = {
        days: document.getElementById('days'),
        hours: document.getElementById('hours'),
        minutes: document.getElementById('minutes'),
        seconds: document.getElementById('seconds')
      };

      if (!elements.days) return;

      const interval = setInterval(() => {
        const now = new Date().getTime();
        const difference = targetDate - now;

        if (difference <= 0) {
          clearInterval(interval);
          Object.values(elements).forEach(el => { if (el) el.textContent = "00"; });
          return;
        }

        const stats = {
          days: Math.floor(difference / (1000 * 60 * 60 * 24)),
          hours: Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)),
          minutes: Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60)),
          seconds: Math.floor((difference % (1000 * 60)) / 1000)
        };

        (Object.keys(stats) as Array<keyof typeof stats>).forEach(key => {
          const el = elements[key];
          if (el) el.textContent = stats[key].toString().padStart(2, '0');
        });
      }, 1000);
    }
  
    document.addEventListener('astro:page-load', initCountdown);
    initCountdown();

    // ── Waitlist form ─────────────────────────────────────────────────────────
    function initWaitlistForm() {
      const form      = document.getElementById('waitlist-form')   as HTMLFormElement | null;
      const emailEl   = document.getElementById('waitlist-email')  as HTMLInputElement | null;
      const submitEl  = document.getElementById('waitlist-submit') as HTMLButtonElement | null;
      const successEl = document.getElementById('waitlist-success');
      const errorEl   = document.getElementById('waitlist-error');
      const privacyEl = document.getElementById('privacy-en') as HTMLInputElement | null;

      if (!form || !emailEl || !submitEl) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        if (privacyEl && !privacyEl.checked) {
          showError('You must accept the privacy policy to continue.');
          return;
        }

        const email = emailEl.value.trim();
        if (!email) return;

        setLoading(true);
        hideMessages();

        try {
          const res = await fetch('/api/submit-contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });

          const data = await res.json();

          if (res.ok && data.success) {
            showSuccess();
            form.reset();
          } else {
            showError(data.error || 'Something went wrong. Please try again.');
          }
        } catch {
          showError('Connection error. Check your internet and try again.');
        } finally {
          setLoading(false);
        }
      });

      function setLoading(loading: boolean) {
        if (!submitEl) return;
        submitEl.disabled = loading;
        submitEl.textContent = loading ? 'Sending…' : 'Let me know!';
      }

      function hideMessages() {
        successEl?.classList.add('hidden');
        errorEl?.classList.add('hidden');
      }

      function showSuccess() {
        successEl?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
        form?.classList.add('hidden');
      }

      function showError(msg: string) {
        if (errorEl) {
          errorEl.textContent = msg;
          errorEl.classList.remove('hidden');
        }
        successEl?.classList.add('hidden');
      }
    }

    document.addEventListener('astro:page-load', initWaitlistForm);
    initWaitlistForm();
  </script>
</BaseLayout>
