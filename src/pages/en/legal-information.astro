---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Legal Information • Mónica Montúfar"
  description="Legal information, intellectual property and terms of use for monicamontufar.com."
  lang="en"
  alternateHref="/informacion-legal/"
>
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-20 md:pt-20">

    <p class="text-xs font-sans font-semibold uppercase tracking-widest text-[#e6b319] mb-3">Legal</p>
    <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-10">Legal Information</h1>

    <div class="prose prose-invert prose-lg max-w-none font-sans font-light text-white/70 space-y-10
                [&_h2]:font-serif [&_h2]:font-bold [&_h2]:text-white [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4
                [&_strong]:text-white/90 [&_a]:text-[#e6b319] [&_a:hover]:text-white">

      <section>
        <h2>1. Website owner</h2>
        <p>
          This website is managed by <strong>Mónica Montúfar</strong>, independent digital content creator,
