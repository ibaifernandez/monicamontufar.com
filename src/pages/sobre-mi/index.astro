---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InternalHero from '../../components/sections/InternalHero.astro';
import { Image } from 'astro:assets';
import imgProfile from '~/assets/wp-content/uploads/2025/06/Monica-Montufar.jpeg';
---

<BaseLayout
  title="Sobre Mí • Mónica Montúfar"
  description="Creativa por convicción, diseñadora por vocación, nómada digital por decisión."
  ogImage="/images/og-home.jpg"
  lang="es"
  alternateHref="https://monicamontufar.com/en/about-me/"
>
  <InternalHero 
    title="Sobre Mí" 
    subtitle="Creativa por convicción, diseñadora por vocación, nómada digital por decisión." 
    lang="es" 
  />

  <!-- Bio + Photo -->
  <section class="max-w-5xl mx-auto px-6 py-12 md:py-24">
    <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-center">
      <div class="w-full md:w-5/12 relative group">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden border border-white/10 relative z-10 transition-transform duration-500 group-hover:-translate-y-2 group-hover:-translate-x-2">
          <Image
            src={imgProfile}
            alt="Mónica Montúfar"
            widths={[320, 480, 640, 960]}
            sizes="(max-width: 768px) 100vw, 42vw"
            quality={80}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#12110e] via-transparent to-transparent opacity-60"></div>
        </div>
        <div class="absolute inset-0 border border-[#e6b319]/40 rounded-2xl z-0 transition-transform duration-500 group-hover:translate-x-4 group-hover:translate-y-4"></div>
      </div>

      <div class="w-full md:w-7/12 space-y-8">
        <div>
          <p class="text-xs font-sans font-semibold uppercase tracking-widest text-[#e6b319] mb-3">Mi Historia</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-white">Creatividad, estrategia<br/>y vida en movimiento</h2>
          <div class="w-12 h-1 bg-[#e6b319] mt-4 rounded-full"></div>
        </div>

        <div class="space-y-6 font-sans text-white/80 leading-relaxed text-lg font-light">
          <p>
            Soy <strong class="text-white font-medium">Mónica Montúfar</strong> —diseñadora gráfica, asistente virtual y nómada digital colombiana. Con más de 10 años en el ecosistema digital y un Máster en Marketing Digital e eCommerce, combino visión creativa con ejecución técnica para ayudar a marcas y emprendedores a crecer sin caos.
          </p>
          <p>
            Dominio avanzado de <strong class="text-[#e6b319] font-medium">WordPress, Mailchimp, Brevo, Email Studio de Salesforce, Illustrator y After Effects</strong>. Especialista en <strong class="text-white font-medium">diseño web, email marketing, gestión de proyectos y comunicación visual</strong>.
          </p>
          <p>
            En 2023 tomé la decisión que cambió mi vida: empacar lo esencial y trabajar desde cualquier lugar del mundo. Desde entonces, he gestionado proyectos remotos para clientes en América Latina y Europa, sin sacrificar ni un gramo de calidad —solo ganando perspectiva, cultura y libertad.
          </p>
        </div>

        <div class="pt-4 flex flex-wrap gap-4">
          <a href="/portafolio/" class="inline-block px-8 py-4 bg-[#e6b319] text-[#12110e] font-sans font-semibold rounded-full hover:bg-white transition-colors duration-300 shadow-[0_4px_14px_0_rgba(230,179,25,0.39)] hover:shadow-[0_6px_20px_rgba(255,255,255,0.23)]">
            Ver mi trabajo
          </a>
          <a href="/contacto/" class="inline-block px-8 py-4 border border-white/20 text-white font-sans font-semibold rounded-full hover:border-[#e6b319]/50 hover:text-[#e6b319] transition-colors duration-300">
            Hablemos
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Herramientas -->
  <section class="bg-[#0f0e0b] border-t border-white/5 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-xs font-sans font-semibold uppercase tracking-widest text-[#e6b319] mb-3">Stack</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-white">Mis herramientas</h2>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {[
          { name: 'WordPress', cat: 'Web' },
          { name: 'Elementor', cat: 'Web' },
          { name: 'Illustrator', cat: 'Diseño' },
          { name: 'Photoshop', cat: 'Diseño' },
          { name: 'After Effects', cat: 'Video' },
          { name: 'Premiere Pro', cat: 'Video' },
          { name: 'Canva', cat: 'Diseño' },
          { name: 'Mailchimp', cat: 'Email' },
          { name: 'Brevo', cat: 'Email' },
          { name: 'Salesforce', cat: 'Email' },
          { name: 'Notion', cat: 'Gestión' },
          { name: 'Trello', cat: 'Gestión' },
        ].map(tool => (
          <div class="flex flex-col gap-1 p-4 rounded-xl border border-white/8 bg-white/3 hover:border-[#e6b319]/30 hover:bg-white/5 transition-all duration-300 group">
            <span class="text-[10px] font-sans font-semibold uppercase tracking-widest text-[#e6b319]/70 group-hover:text-[#e6b319] transition-colors">{tool.cat}</span>
            <span class="font-sans text-white/90 font-medium text-sm">{tool.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué yo -->
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-xs font-sans font-semibold uppercase tracking-widest text-[#e6b319] mb-3">Valores</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-white">¿Por qué trabajar conmigo?</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          {
            icon: 'verified',
            title: 'Calidad sin negociación',
            body: 'Cada entregable pasa por un filtro de exigencia personal. No envío nada que no me enorgullezca firmar.',
          },
          {
            icon: 'schedule',
            title: 'Puntualidad y transparencia',
            body: 'Comunico avances, bloqueos y fechas con claridad. Confiar en mí no debería costar esfuerzo.',
          },
          {
            icon: 'public',
            title: 'Perspectiva global',
            body: 'Trabajar desde distintos países y culturas me da una mirada fresca, adaptable y sin sesgos de burbuja.',
          },
          {
            icon: 'hub',
            title: 'Visión integral',
            body: 'Diseño y estrategia digital no son mundos separados en mi cabeza. Los uno para darte soluciones coherentes.',
          },
        ].map(item => (
          <div class="flex gap-5 p-6 rounded-2xl border border-white/8 bg-white/3 hover:border-[#e6b319]/20 transition-all duration-300">
            <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-[#e6b319]/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-[#e6b319] text-xl">{item.icon}</span>
            </div>
            <div>
              <h3 class="font-sans font-semibold text-white mb-2">{item.title}</h3>
              <p class="font-sans text-white/60 text-sm font-light leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-[#0f0e0b] border-t border-white/5 py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6 text-center space-y-6">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-white">¿Lista para empezar?</h2>
      <p class="font-sans text-white/60 font-light text-lg">Cuéntame en qué estás trabajando y vemos cómo puedo ayudarte.</p>
      <a href="/contacto/" class="inline-block px-10 py-4 bg-[#e6b319] text-[#12110e] font-sans font-semibold rounded-full hover:bg-white transition-colors duration-300 shadow-[0_4px_14px_0_rgba(230,179,25,0.39)]">
        Contáctame
      </a>
    </div>
  </section>
</BaseLayout>
