---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto • Mónica Montúfar"
  description="¿Tienes un proyecto en mente? Cuéntame. Estoy lista para ayudarte a crecer sin caos."
  lang="es"
  omitAlternate={true}
>
  <!-- Header -->
  <section class="max-w-4xl mx-auto px-6 pt-12 pb-10 md:pt-20 md:pb-12 text-center">
    <p class="text-xs font-sans font-semibold uppercase tracking-widest text-[#e6b319] mb-3">Contacto</p>
    <h1 class="text-4xl md:text-6xl font-serif font-bold text-white mb-5">
      Hablemos
    </h1>
    <p class="font-sans text-white/60 font-light text-lg max-w-xl mx-auto">
      ¿Tienes un proyecto, una pregunta o simplemente quieres saludar? Escríbeme y te responderé tan pronto como me sea posible.
    </p>
  </section>

  <!-- Layout: form + info -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16">

      <!-- Info sidebar -->
      <aside class="lg:col-span-2 space-y-8">

        <div class="space-y-3">
          <h2 class="font-serif text-xl font-bold text-white">Datos de contacto</h2>
          <div class="w-8 h-0.5 bg-[#e6b319] rounded-full"></div>
        </div>

        <div class="space-y-5">
          <a
            href="mailto:hola@monicamontufar.com"
            class="flex items-start gap-4 group"
          >
            <div class="w-10 h-10 rounded-xl bg-[#e6b319]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#e6b319]/20 transition-colors">
              <span class="material-symbols-outlined text-[#e6b319] text-xl">mail</span>
            </div>
            <div>
              <p class="text-xs font-sans font-semibold uppercase tracking-widest text-white/40 mb-1">Email</p>
              <p class="font-sans text-white/80 group-hover:text-[#e6b319] transition-colors text-sm">hola@monicamontufar.com</p>
            </div>
          </a>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[#e6b319]/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-[#e6b319] text-xl">public</span>
            </div>
            <div>
              <p class="text-xs font-sans font-semibold uppercase tracking-widest text-white/40 mb-1">Ubicación</p>
              <p class="font-sans text-white/80 text-sm">Nómada digital — desde donde el mundo me lleve</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[#e6b319]/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-[#e6b319] text-xl">schedule</span>
            </div>
            <div>
              <p class="text-xs font-sans font-semibold uppercase tracking-widest text-white/40 mb-1">Respondo en</p>
              <p class="font-sans text-white/80 text-sm">24 – 48 horas hábiles</p>
            </div>
          </div>
        </div>

        <!-- Social -->
        <div class="pt-4 space-y-3">
          <p class="text-xs font-sans font-semibold uppercase tracking-widest text-white/40">Redes sociales</p>
          <div class="flex gap-3">
            <a href="https://www.facebook.com/lospensamientosdeMon" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
               class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-[#e6b319] hover:border-[#e6b319]/40 transition-all duration-200">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="https://www.instagram.com/los_pensamientos_de_mon" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
               class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-[#e6b319] hover:border-[#e6b319]/40 transition-all duration-200">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="https://www.tiktok.com/@los_pensamientos_de_mon" target="_blank" rel="noopener noreferrer" aria-label="TikTok"
               class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-slate-400 hover:text-[#e6b319] hover:border-[#e6b319]/40 transition-all duration-200">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
              </svg>
            </a>
          </div>
        </div>
      </aside>

      <!-- Contact form -->
      <div class="lg:col-span-3">
        <form
          name="contacto"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6"
          id="contact-form"
        >
          <!-- Netlify hidden fields -->
          <input type="hidden" name="form-name" value="contacto" />
          <p class="hidden">
            <label>No rellenar: <input name="bot-field" /></label>
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="nombre" class="block text-xs font-sans font-semibold uppercase tracking-widest text-white/50">
                Nombre <span class="text-[#e6b319]">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 font-sans text-white placeholder-white/30 text-sm focus:outline-none focus:border-[#e6b319]/50 focus:bg-white/8 transition-all duration-200"
              />
            </div>

            <div class="space-y-2">
              <label for="apellido" class="block text-xs font-sans font-semibold uppercase tracking-widest text-white/50">
                Apellido
              </label>
              <input
                type="text"
                id="apellido"
                name="apellido"
                placeholder="Tu apellido"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 font-sans text-white placeholder-white/30 text-sm focus:outline-none focus:border-[#e6b319]/50 focus:bg-white/8 transition-all duration-200"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label for="email" class="block text-xs font-sans font-semibold uppercase tracking-widest text-white/50">
              Email <span class="text-[#e6b319]">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@email.com"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 font-sans text-white placeholder-white/30 text-sm focus:outline-none focus:border-[#e6b319]/50 focus:bg-white/8 transition-all duration-200"
            />
          </div>

          <div class="space-y-2">
            <label for="pais" class="block text-xs font-sans font-semibold uppercase tracking-widest text-white/50">
              País
            </label>
            <input
              type="text"
              id="pais"
              name="pais"
              placeholder="Tu país"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 font-sans text-white placeholder-white/30 text-sm focus:outline-none focus:border-[#e6b319]/50 focus:bg-white/8 transition-all duration-200"
            />
          </div>

          <div class="space-y-2">
            <label for="mensaje" class="block text-xs font-sans font-semibold uppercase tracking-widest text-white/50">
              Mensaje <span class="text-[#e6b319]">*</span>
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="6"
              placeholder="Cuéntame sobre tu proyecto, idea o consulta..."
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 font-sans text-white placeholder-white/30 text-sm focus:outline-none focus:border-[#e6b319]/50 focus:bg-white/8 transition-all duration-200 resize-none"
            ></textarea>
          </div>

          <div class="pt-2">
            <button
              type="submit"
              class="w-full sm:w-auto px-10 py-4 bg-[#e6b319] text-[#12110e] font-sans font-semibold rounded-full hover:bg-white transition-colors duration-300 shadow-[0_4px_14px_0_rgba(230,179,25,0.39)] hover:shadow-[0_6px_20px_rgba(255,255,255,0.23)] inline-flex items-center justify-center gap-2 group"
            >
              Enviar mensaje
              <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">send</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
