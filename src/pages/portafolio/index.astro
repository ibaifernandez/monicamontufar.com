---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InternalHero from '../../components/sections/InternalHero.astro';
import PremiumCard from '../../components/ui/PremiumCard.astro';
import PortfolioGrid from '../../components/sections/PortfolioGrid.astro';

import imgPapeleria from '~/assets/wp-content/uploads/2023/08/Papeleria-creativa.png';
import imgSocial from '~/assets/wp-content/uploads/2023/08/Social-media.png';
import imgDisenoWeb from '~/assets/wp-content/uploads/2024/05/Diseno-web.jpeg';
import imgBranding from '~/assets/wp-content/uploads/2023/08/Branding-08.png';
import imgSocialFattache from '~/assets/wp-content/uploads/2023/08/Social-media-fattache.png';
import imgRegalosMama from '~/assets/wp-content/uploads/2023/08/Regalos-para-mama-Andariega-73.jpg';
---

<BaseLayout
  title="Portafolio • Mónica Montúfar"
  description="Descubre mis servicios de Asistencia Virtual y Diseño."
  lang="es"
  alternateHref="https://monicamontufar.com/en/portfolio/"
>
  <InternalHero 
    title="Portafolio" 
    subtitle="Tiempo libre y procesos optimizados mientras tu negocio escala sin límites." 
    lang="es" 
  />

  <section class="max-w-7xl mx-auto px-6 py-12">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-serif font-bold text-white mb-4">Servicios</h2>
      <p class="font-sans text-white/70 max-w-2xl mx-auto text-lg font-light">Soluciones integrales para optimizar tus operaciones y elevar la presencia de tu marca.</p>
    </div>

    <PortfolioGrid>
      <PremiumCard
        isLCP={true}
        title="Gestión y Organización"
        description="Gestión eficiente de agendas, correos electrónicos y documentación confidencial."
        image={imgPapeleria}
        tags={['Asistencia Virtual']}
      />
      <PremiumCard 
        title="Marketing Digital"
        description="Estrategias de email marketing, gestión de redes sociales y diseño de newsletters (Mailchimp, Brevo)."
        image={imgSocial}
        tags={['Redes Sociales', 'Email']}
      />
      <PremiumCard 
        title="Soporte Web y Diseño"
        description="Mantenimiento integral de WordPress, diseño de landing pages y creación de piezas visuales."
        image={imgDisenoWeb}
        tags={['WordPress', 'Diseño Web']}
      />
      <PremiumCard 
        title="Branding"
        description="Naming, Arquitectura y Valor de Marca. Desde la identidad visual hasta el posicionamiento con Illustrator y Photoshop."
        image={imgBranding}
        tags={['Identidad Visual']}
      />
      <PremiumCard 
        title="Diseño Multimedia"
        description="Creación de piezas audiovisuales para promoción de servicios en medios digitales (After Effects & Premiere)."
        image={imgSocialFattache}
        tags={['Video', 'Animación']}
      />
      <PremiumCard 
        title="Fotografía de Producto"
        description="Producción y edición profesional de fotografías de producto en estudio con calidad de agencia."
        image={imgRegalosMama}
        tags={['Fotografía', 'Lightroom']}
      />
    </PortfolioGrid>
  </section>

  <section class="relative w-full py-24 md:py-32 mt-12 bg-white/[0.02] border-t border-white/5 overflow-hidden">
    <!-- Glow -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#e6b319]/5 blur-[120px] rounded-full pointer-events-none -translate-y-1/2 translate-x-1/2"></div>
    
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-serif font-bold text-white mb-6">Modelo de Trabajo</h2>
        <p class="font-sans text-white/80 leading-relaxed max-w-3xl mx-auto text-lg font-light">Mi objetivo es adaptarme a tus necesidades, ofreciéndote un soporte de Asistencia Virtual de alta calidad con la flexibilidad que tu negocio requiere.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-10 border border-white/10 rounded-3xl bg-white/5 backdrop-blur-md transition-transform duration-300 hover:-translate-y-2 hover:border-white/20">
          <h3 class="font-serif text-2xl font-bold text-white mb-2">Inicial</h3>
          <p class="text-[#e6b319] font-bold text-xl mb-6 font-sans">10 horas/mes</p>
          <p class="text-base text-white/70 font-light leading-relaxed">Ideal para soporte puntual, organización de correos y tareas administrativas específicas.</p>
        </div>
        <div class="p-10 border border-[#e6b319]/30 rounded-3xl bg-gradient-to-b from-[#e6b319]/10 to-transparent backdrop-blur-md transform md:-translate-y-6 shadow-[0_20px_40px_rgba(230,179,25,0.1)] transition-transform duration-300 hover:-translate-y-8">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#e6b319] text-[#12110e] text-xs font-bold uppercase tracking-widest py-1 px-4 rounded-full">Popular</div>
          <h3 class="font-serif text-2xl font-bold text-white mb-2">Pro</h3>
          <p class="text-[#e6b319] font-bold text-xl mb-6 font-sans">20 horas/mes</p>
          <p class="text-base text-white/70 font-light leading-relaxed">Perfecto para una asistencia más continua, proyectos en desarrollo y gestión de redes.</p>
        </div>
        <div class="p-10 border border-white/10 rounded-3xl bg-white/5 backdrop-blur-md transition-transform duration-300 hover:-translate-y-2 hover:border-white/20">
          <h3 class="font-serif text-2xl font-bold text-white mb-2">Premium</h3>
          <p class="text-[#e6b319] font-bold text-xl mb-6 font-sans">40 horas/mes</p>
          <p class="text-base text-white/70 font-light leading-relaxed">Tu solución integral para delegar significativamente y acelerar el crecimiento de tu empresa.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
