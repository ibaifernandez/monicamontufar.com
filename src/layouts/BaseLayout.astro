---
import SEO from '../components/global/SEO.astro';
import CookieBanner from '../components/global/CookieBanner.astro';
import '../styles/global.css';
import imgIcono from '~/assets/wp-content/uploads/2023/08/Icono-Mon.png';
import imgHero from '~/assets/wp-content/uploads/2024/04/MonMont.jpeg';

interface Props {
  title: string;
  description: string;
  lang?: 'es' | 'en';
}

const { title, description, lang = 'es' } = Astro.props;
---

<!doctype html>
<!-- Force dark mode for this premium look as requested by Stitch design -->
<html lang={lang} class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={imgIcono.src} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO & Social Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(imgHero.src, Astro.site || Astro.url).href} />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    
    <!-- Internationalization Hreflang Tags -->
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang="es" href={new URL('/', Astro.site || Astro.url).href} />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site || Astro.url).href} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site || Astro.url).href} />
    
    <SEO title={title} description={description} lang={lang} />    
    <!-- Google Fonts for Stitch Design -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#12110E] text-slate-100 font-display antialiased overflow-x-hidden min-h-screen flex flex-col selection:bg-primary/30">
    <main class="flex-grow flex flex-col">
      <slot />
    </main>
    <CookieBanner lang={lang} />
  </body>
</html>
