---
import SEO from '../components/global/SEO.astro';
import CookieBanner from '../components/global/CookieBanner.astro';
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/playfair-display';
import imgIcono from '~/assets/wp-content/uploads/2023/08/Icono-Mon.png';

interface Props {
  title: string;
  description: string;
  lang?: 'es' | 'en';
  ogImage?: string;
  alternateHref?: string;
}

const { title, description, lang = 'es', ogImage, alternateHref } = Astro.props;
---

<!doctype html>
<html lang={lang} class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={imgIcono.src} />
    <meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} lang={lang} image={ogImage} alternateHref={alternateHref} />

    <!-- Material Symbols: carga async (non-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"></noscript>
  </head>
  <body class="bg-[#12110E] text-slate-100 font-display antialiased overflow-x-hidden min-h-screen flex flex-col selection:bg-primary/30">
    <main class="flex-grow flex flex-col">
      <slot />
    </main>
    <CookieBanner lang={lang} />
  </body>
</html>
