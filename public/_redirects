# _redirects configuration
# Block sensitive paths — syntax: /source  /destination  status
/.env        /404.html  404
/.git*       /404.html  404
/wp-admin*   /404.html  404
/wp-login*   /404.html  404
/xmlrpc.php  /404.html  404

# Blog posts referenced from content but not migrated from WordPress → redirect to blog
/mi-viaje-hacia-ser-una-nomada-digital/          /blog/  301
/13-pasos-para-convertirte-en-un-nomada-digital/ /blog/  301

# Netlify sirve /404.html automáticamente para rutas no encontradas (generado por src/pages/404.astro).
