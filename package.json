{
  "name": "monicamontufar.com-astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/prepare-wp-uploads.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:visual:docker": "docker run --rm --ipc=host -e CI=true -v \"$(pwd)\":/work/ -w /work/ mcr.microsoft.com/playwright:v1.58.2-noble bash -c 'npm install @rollup/rollup-linux-arm64-gnu @rollup/rollup-linux-x64-gnu @rollup/rollup-linux-x64-musl --no-save --force && npm run build && npx playwright test tests/quality-gate.spec.ts --update-snapshots'",
    "astro": "astro"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.6",
    "resend": "^6.9.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@netlify/functions": "^5.1.5",
    "@playwright/test": "^1.58.2",
    "@sentry/astro": "^10.45.0",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.0"
  }
}
